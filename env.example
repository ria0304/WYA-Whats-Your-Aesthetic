# ===========================================
# WYA — What's Your Aesthetic
# ===========================================

# ── Environment ───────────────────────────
DEBUG=false
NODE_ENV=production

# ── JWT ───────────────────────────────────
# Generate with: python -c "import secrets; print(secrets.token_hex(32))"
JWT_SECRET=

# ── AWS ───────────────────────────────────
AWS_REGION=ap-south-1
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=

# ── AWS Secrets Manager ───────────────────
USE_SECRETS_MANAGER=false
SECRET_ID_PATH=wya/jwt-secret

# ── SageMaker ─────────────────────────────
SAGEMAKER_ENDPOINT=wya-fashionclip-serverless

# ── CloudFront / App URL ──────────────────
CLOUDFRONT_DOMAIN=dsbml6kwxecah.cloudfront.net
WYA_APP_BASE_URL=https://dsbml6kwxecah.cloudfront.net

# ── AI / ML APIs ──────────────────────────
OPENROUTER_API_KEY=
HF_TOKEN=

# ── Geolocation ───────────────────────────
GEOAPIFY_API_KEY=

# ── Email (Gmail SMTP) ────────────────────
WYA_GMAIL_ADDRESS=wya123@gmail.com
WYA_GMAIL_APP_PASS=

# ── Push Notifications (VAPID) ────────────
WYA_VAPID_PUBLIC_KEY=
WYA_VAPID_PRIVATE_KEY=

# ── Extra CORS Origins (optional, comma-separated) ────────────────────────────
# EXTRA_ORIGINS=https://a.com,https://b.com
